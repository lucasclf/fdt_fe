---
import BaseLayout from "../layouts/BaseLayout.astro";
import { paginas } from "../data/paginas";

const paragrafos = paginas.ferimentoEMorte
  .split(/\n\s*\n/)
  .map((paragrafo) => paragrafo.trim())
  .filter(Boolean);
---

<BaseLayout title="Ferimento e morte de parceiros" description="Regras de ferimento e morte de parceiros.">
  <section class="hero">
    <span class="hero-eyebrow">Regras</span>
    <h1>Ferimento e morte de parceiros</h1>
    <p>Página reservada para as regras de ferimento e morte dos parceiros.</p>
  </section>

  <article class="content-card">
    <div class="notice">
      O conteúdo original desta página parece não ter vindo nos anexos. Substitua o texto em
      <code>src/data/paginas.ts</code> quando tiver a versão correta.
    </div>

    {paragrafos.map((paragrafo) => (
      <p>{paragrafo}</p>
    ))}
  </article>
</BaseLayout>
