---
import BaseLayout from "../layouts/BaseLayout.astro";
import { parceiros, tiposDisponiveis } from "../data/parceiros";

const parceirosComTipo = parceiros.filter((parceiro) => parceiro.tipos.length > 0).length;
---

<BaseLayout title="Parceiros">
  <section class="hero">
    <span class="hero-eyebrow">Compêndio</span>
    <h1>Parceiros, regras e tipos em um site estático.</h1>
    <p>
      Use esta base para consultar NPCs, habilidades, tipos de parceiros e regras durante a mesa.
      O projeto não usa backend, banco de dados ou autenticação.
    </p>

    <div class="action-row">
      <a class="button" href="/parceiros">Ver lista de parceiros</a>
      <a class="button secondary" href="/tipos-de-parceiros">Ver tipos</a>
    </div>
  </section>

  <section class="stats-grid" aria-label="Resumo do conteúdo">
    <article class="stat-card">
      <strong>{parceiros.length}</strong>
      <span>parceiros cadastrados</span>
    </article>

    <article class="stat-card">
      <strong>{tiposDisponiveis.length}</strong>
      <span>tipos disponíveis para filtro</span>
    </article>

    <article class="stat-card">
      <strong>{parceirosComTipo}</strong>
      <span>parceiros com ao menos um tipo detectado</span>
    </article>
  </section>
</BaseLayout>
